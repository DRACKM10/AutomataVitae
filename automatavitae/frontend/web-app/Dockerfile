FROM node:20-alpine

WORKDIR /app

COPY package*.json ./

RUN npm install

COPY . .

# 1. Declarar los argumentos que vas a recibir al compilar
ARG NEXT_PUBLIC_USER_SERVICE_URL
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ARG NEXT_PUBLIC_CV_SERVICE_URL
ARG NEXT_PUBLIC_IA_SERVICE_URL
ARG NEXT_PUBLIC_PDF_SERVICE_URL

# 2. Convertirlos en variables de entorno para el proceso de build
ENV NEXT_PUBLIC_USER_SERVICE_URL=$NEXT_PUBLIC_USER_SERVICE_URL
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_CV_SERVICE_URL=$NEXT_PUBLIC_CV_SERVICE_URL
ENV NEXT_PUBLIC_IA_SERVICE_URL=$NEXT_PUBLIC_IA_SERVICE_URL
ENV NEXT_PUBLIC_PDF_SERVICE_URL=$NEXT_PUBLIC_PDF_SERVICE_URL

# 3. Ahora sí, construimos la aplicación
RUN npm run build

RUN npm install -g serve

EXPOSE 3000

CMD ["serve", "-s", "out", "-l", "3000"]
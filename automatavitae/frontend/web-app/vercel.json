{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/users/:match*",
      "destination": "https://TU_DOMINIO_PUBLICO_USER_SERVICE/api/v1/auth/:match*"
    },
    {
      "source": "/api/cvs/:match*",
      "destination": "https://TU_DOMINIO_PUBLICO_CV_SERVICE/api/v1/cvs/:match*"
    },
    {
      "source": "/api/pdf/:match*",
      "destination": "https://TU_DOMINIO_PUBLICO_PDF_SERVICE/api/v1/pdf/:match*"
    },
    {
      "source": "/api/cv/:match*",
      "destination": "https://TU_DOMINIO_PUBLICO_CV_ANALYZER/api/analyze/:match*"
    },
    {
      "source": "/api/payments/:match*",
      "destination": "https://TU_DOMINIO_PUBLICO_CV_ANALYZER/api/payments/:match*"
    },
    {
      "source": "/api/ia/:match*",
      "destination": "https://TU_DOMINIO_PUBLICO_MICROSERVICIO_IA/api/:match*"
    }
  ]
}
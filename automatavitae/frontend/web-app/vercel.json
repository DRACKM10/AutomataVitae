{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/users/:match*",
      "destination": "https://user-servicee.up.railway.app/api/v1/auth/:match*"
    },
    {
      "source": "/api/cvs/:match*",
      "destination": "https://cv-service.up.railway.app/api/v1/cvs/:match*"
    },
    {
      "source": "/api/pdf/:match*",
      "destination": "https://pdf-services.up.railway.app/api/v1/pdf/:match*"
    },
    {
      "source": "/api/cv/:match*",
      "destination": "https://cv-analyzer.up.railway.app/api/analyze/:match*"
    },
    {
      "source": "/api/payments/:match*",
      "destination": "https://cv-analyzer.up.railway.app/api/payments/:match*"
    },
    {
      "source": "/api/ia/:match*",
      "destination": "https://microservicioia.up.railway.app/api/:match*"
    }
  ]
}